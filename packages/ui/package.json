{
  "name": "@aspekt/ui",
  "version": "0.3.1",
  "description": "CLI for adding Aspekt UI source components to React and Tailwind projects.",
  "type": "module",
  "bin": {
    "aspekt": "cli.js"
  },
  "files": [
    "cli.js",
    "templates",
    "README.md"
  ],
  "scripts": {
    "templates:sync": "node scripts/sync-templates.mjs",
    "dev": "node cli.js",
    "pack:dry-run": "pnpm pack --dry-run",
    "prepack": "node scripts/sync-templates.mjs",
    "prepublishOnly": "node scripts/sync-templates.mjs"
  },
  "engines": {
    "node": ">=18.18"
  },
  "publishConfig": {
    "access": "public"
  }
}
