  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4.3.1",
    "typescript": "^5"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
